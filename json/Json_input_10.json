{
  "description": "Hidraulica de tuberias — redes de distribucion",
  "variables": [
    { "name": "BOMBA_OK",           "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "VALVULA_PRESION_OK", "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "FILTRO_OK",          "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "CAVITACION",         "type": "boolean", "domain": [true, false], "value": [false] },
    { "name": "SISTEMA_VERIFICADO", "type": "boolean", "domain": [true, false], "value": [false] },
    { "name": "MATERIAL_TUBERIA","type": "set", "domain": ["ACERO","PVC","HDPE","COBRE"],          "value": ["ACERO","HDPE"] },
    { "name": "TIPO_FLUIDO",     "type": "set", "domain": ["AGUA","ACEITE","COMBUSTIBLE","QUIMICO"],"value": ["AGUA"] },
    { "name": "REGIMEN_FLUJO",   "type": "set", "domain": ["LAMINAR","TRANSITORIO","TURBULENTO"],  "value": ["TURBULENTO"] },
    { "name": "DIAMETRO_NOM_MM","type": "integer", "domain": [25,32,40,50,65,80,100,125,150,200], "value": [80,100,125] },
    { "name": "NUM_CODOS",      "type": "integer", "domain": [0,1,2,3,4,5,6,7,8],                 "value": [2,3,4] },
    { "name": "PRESION_BAR",    "type": "numeric", "domain": [0.5, 20.0],                          "value": [4.0, 6.0] }
  ],
  "functions": [
    {
      "name": "velocidad_media",
      "inputs":  [{ "name": "caudal_m3h",  "type": "numeric", "domain": [0.0, 1000.0] },
                  { "name": "diametro_mm", "type": "numeric", "domain": [10.0, 500.0] }],
      "outputs": [{ "name": "v_ms",        "type": "numeric", "domain": [0.0, 20.0]   }]
    },
    {
      "name": "perdida_friccion",
      "inputs":  [{ "name": "velocidad",   "type": "numeric", "domain": [0.0, 20.0]   },
                  { "name": "longitud_m",  "type": "numeric", "domain": [0.0, 5000.0] },
                  { "name": "diametro_m",  "type": "numeric", "domain": [0.01, 2.0]   }],
      "outputs": [{ "name": "hf_m",        "type": "numeric", "domain": [0.0, 500.0]  }]
    }
  ],
  "expressions": [
    { "constraints": ["BOMBA_OK = true AND VALVULA_PRESION_OK = true"] },
    { "constraints": ["FILTRO_OK = true"] },
    { "constraints": ["CAVITACION = false AND SISTEMA_VERIFICADO = false"] },
    { "constraints": ["MATERIAL_TUBERIA IN {ACERO, HDPE, PVC}"] },
    { "constraints": ["TIPO_FLUIDO IN {AGUA, ACEITE}"] },
    { "constraints": ["REGIMEN_FLUJO IN {LAMINAR, TURBULENTO}"] },
    { "constraints": ["DIAMETRO_NOM_MM IN [50, 200]"] },
    { "constraints": ["NUM_CODOS IN [0, 6]"] },
    { "constraints": ["PRESION_BAR IN [2.0, 10.0]"] },
    { "constraints": ["sqrt(PRESION_BAR) IN [1.4, 3.2]"] },
    { "constraints": ["abs(PRESION_BAR - 5.0) <= 1.5"] },
    { "constraints": ["velocidad_media(25.0, DIAMETRO_NOM_MM) IN [0.5, 3.0]"] },
    { "constraints": ["perdida_friccion(2.0, 50.0, NUM_CODOS) IN [0.01, 5.0]"] }
  ]
}
