{
  "description": "Metrologia dimensional de piezas cilindricas",
  "variables": [
    { "name": "PIEZA_OK",       "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "RUGOSIDAD_OK",   "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "CALIBRE_OK",     "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "SIMETRIA_OK",    "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "CERTIFICADO_OK", "type": "boolean", "domain": [true, false], "value": [false] },
    { "name": "MATERIAL",          "type": "set", "domain": ["ACERO","ALUMINIO","TITANIO","BRONCE"],  "value": ["ACERO","ALUMINIO"] },
    { "name": "ACABADO",           "type": "set", "domain": ["N6","N7","N8","N9"],                    "value": ["N7","N8"] },
    { "name": "PROCESO_MECANIZADO","type": "set", "domain": ["TORNEADO","RECTIFICADO","FRESADO"],     "value": ["RECTIFICADO"] },
    { "name": "MUESTRAS",     "type": "integer", "domain": [5,10,15,20,25,30], "value": [10,15,20] },
    { "name": "MEDICIONES",   "type": "integer", "domain": [3,5,7,10],         "value": [5,7] },
    { "name": "DIAMETRO_MM",  "type": "numeric", "domain": [40.0, 60.0],       "value": [49.8, 50.2] }
  ],
  "functions": [
    {
      "name": "desviacion_relativa",
      "inputs":  [{ "name": "valor",   "type": "numeric", "domain": [0.0, 1e6] },
                  { "name": "nominal", "type": "numeric", "domain": [0.0, 1e6] }],
      "outputs": [{ "name": "pct",     "type": "numeric", "domain": [0.0, 100.0] }]
    }
  ],
  "expressions": [
    { "constraints": ["PIEZA_OK = true AND CALIBRE_OK = true"] },
    { "constraints": ["RUGOSIDAD_OK = true AND SIMETRIA_OK = true"] },
    { "constraints": ["CERTIFICADO_OK = false"] },
    { "constraints": ["MATERIAL IN {ACERO, ALUMINIO, TITANIO}"] },
    { "constraints": ["ACABADO IN {N6, N7, N8}"] },
    { "constraints": ["PROCESO_MECANIZADO IN {TORNEADO, RECTIFICADO}"] },
    { "constraints": ["MUESTRAS IN [5, 30]"] },
    { "constraints": ["MEDICIONES IN [3, 10]"] },
    { "constraints": ["DIAMETRO_MM IN [49.0, 51.0]"] },
    { "constraints": ["abs(DIAMETRO_MM - 50.0) <= 0.5"] },
    { "constraints": ["sqrt(MUESTRAS) >= 3.0"] },
    { "constraints": ["desviacion_relativa(DIAMETRO_MM, 50.0) <= 1.0"] }
  ]
}
