{
  "description": "Analisis estructural de viga de acero",
  "variables": [
    { "name": "VIGA_SIMETRICA",     "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "PANDEO_OK",          "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "DEFORMACION_OK",     "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "ANCLAJE_OK",         "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "CALCULO_VERIFICADO", "type": "boolean", "domain": [true, false], "value": [false] },
    { "name": "SECCION",     "type": "set", "domain": ["IPE200","IPE300","IPE400","HEB200","HEB300"], "value": ["IPE300","HEB200"] },
    { "name": "ACERO_GRADO", "type": "set", "domain": ["S235","S275","S355","S460"],                  "value": ["S275","S355"] },
    { "name": "COND_APOYO",  "type": "set", "domain": ["BIAPOYADA","VOLADIZO","CONTINUA"],            "value": ["BIAPOYADA"] },
    { "name": "LONGITUD_M", "type": "integer", "domain": [2,3,4,5,6,7,8,9,10], "value": [4,5,6] },
    { "name": "NUM_CARGAS", "type": "integer", "domain": [1,2,3,4,5],           "value": [1,2,3] },
    { "name": "CARGA_KN",   "type": "numeric", "domain": [10.0, 500.0],         "value": [80.0, 120.0] }
  ],
  "functions": [
    {
      "name": "tension_admisible",
      "inputs":  [{ "name": "carga_kn", "type": "numeric", "domain": [0.0, 1000.0] },
                  { "name": "area_cm2", "type": "numeric", "domain": [1.0, 500.0]  }],
      "outputs": [{ "name": "tension",  "type": "numeric", "domain": [0.0, 500.0]  }]
    },
    {
      "name": "factor_seguridad",
      "inputs":  [{ "name": "resistencia", "type": "numeric", "domain": [0.0, 2000.0] },
                  { "name": "carga",       "type": "numeric", "domain": [0.0, 1000.0] }],
      "outputs": [{ "name": "fs",          "type": "numeric", "domain": [0.0, 20.0]   }]
    }
  ],
  "expressions": [
    { "constraints": ["VIGA_SIMETRICA = true AND PANDEO_OK = true"] },
    { "constraints": ["DEFORMACION_OK = true AND ANCLAJE_OK = true"] },
    { "constraints": ["CALCULO_VERIFICADO = false"] },
    { "constraints": ["SECCION IN {IPE300, IPE400, HEB200, HEB300}"] },
    { "constraints": ["ACERO_GRADO IN {S275, S355, S460}"] },
    { "constraints": ["COND_APOYO IN {BIAPOYADA, CONTINUA}"] },
    { "constraints": ["LONGITUD_M IN [3, 8]"] },
    { "constraints": ["NUM_CARGAS IN [1, 5]"] },
    { "constraints": ["CARGA_KN IN [50.0, 200.0]"] },
    { "constraints": ["sqrt(LONGITUD_M) <= 3.5"] },
    { "constraints": ["abs(CARGA_KN - 100.0) <= 30.0"] },
    { "constraints": ["tension_admisible(CARGA_KN, 53.8) <= 2.4"] },
    { "constraints": ["factor_seguridad(240.0, CARGA_KN) >= 1.5"] }
  ]
}
