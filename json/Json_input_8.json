{
  "description": "Control estadistico de proceso SPC",
  "variables": [
    { "name": "PROCESO_ESTABLE",  "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "DENTRO_SPEC",      "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "ALARMA_SPC",       "type": "boolean", "domain": [true, false], "value": [false] },
    { "name": "MAQUINA_CALIBRADA","type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "TURNO_COMPLETO",   "type": "boolean", "domain": [true, false], "value": [true]  },
    { "name": "CARACTERISTICA","type": "set", "domain": ["DIAMETRO","LONGITUD","ANGULO","RUGOSIDAD"], "value": ["DIAMETRO","LONGITUD"] },
    { "name": "TURNO",         "type": "set", "domain": ["MANANA","TARDE","NOCHE"],                   "value": ["TARDE"] },
    { "name": "DECISION",      "type": "set", "domain": ["ACEPTAR","RECHAZAR","REINSPECCIONAR","RETENER"], "value": ["ACEPTAR"] },
    { "name": "SUBGRUPO",      "type": "integer", "domain": [2,3,4,5,6,7,8,9,10], "value": [5,6,7] },
    { "name": "MUESTRAS_DIA",  "type": "integer", "domain": [10,20,30,40,50,60],  "value": [20,30,40] },
    { "name": "MEDIA_MM",      "type": "numeric", "domain": [9.5, 10.5],           "value": [9.95, 10.05] }
  ],
  "functions": [
    {
      "name": "rango_normalizado",
      "inputs":  [{ "name": "valor", "type": "numeric", "domain": [-1e9, 1e9] },
                  { "name": "lo",    "type": "numeric", "domain": [-1e9, 1e9] },
                  { "name": "hi",    "type": "numeric", "domain": [-1e9, 1e9] }],
      "outputs": [{ "name": "r",     "type": "numeric", "domain": [0.0, 1.0]  }]
    },
    {
      "name": "cpk",
      "inputs":  [{ "name": "media",   "type": "numeric", "domain": [-1e9, 1e9] },
                  { "name": "lse",     "type": "numeric", "domain": [-1e9, 1e9] },
                  { "name": "lie",     "type": "numeric", "domain": [-1e9, 1e9] }],
      "outputs": [{ "name": "indice",  "type": "numeric", "domain": [-5.0, 5.0] }]
    }
  ],
  "expressions": [
    { "constraints": ["PROCESO_ESTABLE = true AND DENTRO_SPEC = true"] },
    { "constraints": ["ALARMA_SPC = false"] },
    { "constraints": ["MAQUINA_CALIBRADA = true AND TURNO_COMPLETO = true"] },
    { "constraints": ["CARACTERISTICA IN {DIAMETRO, LONGITUD, ANGULO}"] },
    { "constraints": ["TURNO IN {MANANA, TARDE}"] },
    { "constraints": ["DECISION IN {ACEPTAR, REINSPECCIONAR}"] },
    { "constraints": ["SUBGRUPO IN [3, 10]"] },
    { "constraints": ["MUESTRAS_DIA IN [20, 60]"] },
    { "constraints": ["MEDIA_MM IN [9.8, 10.2]"] },
    { "constraints": ["abs(MEDIA_MM - 10.0) <= 0.1"] },
    { "constraints": ["rango_normalizado(MEDIA_MM, 9.5, 10.5) IN [0.4, 0.6]"] },
    { "constraints": ["cpk(MEDIA_MM, 10.3, 9.7) >= 1.33"] }
  ]
}
